#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [[ "$(id -u)" -ne 0 ]]; then
  if ! command -v sudo >/dev/null 2>&1; then
    echo "[ERR] root or sudo is required."
    exit 1
  fi
  echo "[INFO] A one-time sudo authentication is required for netem/initcwnd setup."
  sudo -v
fi

echo "[STEP] running test1 (Fig. 3)"
bash "$ROOT_DIR/testScripts/test1/test1"

echo "[STEP] running test2 (Fig. 4)"
bash "$ROOT_DIR/testScripts/test2/test2"

echo "[STEP] running test3 (Fig. 5)"
bash "$ROOT_DIR/testScripts/test3/test3"

echo "[OK] all experiments completed"
echo "[ARTIFACT] $ROOT_DIR/testScripts/test1/results/test1"
echo "[ARTIFACT] $ROOT_DIR/testScripts/test2/results/test2-C"
echo "[ARTIFACT] $ROOT_DIR/testScripts/test2/results/test2-I"
echo "[ARTIFACT] $ROOT_DIR/testScripts/test2/results/test2-L"
echo "[ARTIFACT] $ROOT_DIR/testScripts/test3/results/test3"
