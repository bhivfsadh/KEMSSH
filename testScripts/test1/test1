#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
RUNNER="$ROOT_DIR/testScripts/backends/run_test1.sh"

OUT_DIR="$ROOT_DIR/testScripts/test1/results/test1"
RESULT_DIR="$OUT_DIR"

# Default reviewer mode (can be overridden by CLI options).
FORMAL_ROUNDS="${FORMAL_ROUNDS:-1}"
FORMAL_WARMUP="${FORMAL_WARMUP:-5}"
FORMAL_ITERATIONS="${FORMAL_ITERATIONS:-50}"
RTT_MS="${RTT_MS:-67}"
INITCWND_MSS="${INITCWND_MSS:-10}"
NETEM_IFACE="${NETEM_IFACE:-lo}"
TEST_HOST="${TEST_HOST:-127.0.0.1}"
TEST_PORT="${TEST_PORT:-42310}"

usage() {
    cat <<'EOF'
Usage:
  bash testScripts/test1/test1 [options]

Options:
  --rounds <n>       Number of rounds (default: 1)
  --iterations <n>   Measured iterations per round (default: 50)
  --warmup <n>       Warmup iterations per round (default: 5)
  --rtt <ms>         RTT in milliseconds (default: 67)
  --initcwnd <mss>   initcwnd in MSS (default: 10)
  --iface <name>     netem interface (default: lo)
  -h, --help         Show help
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rounds)
                FORMAL_ROUNDS="$2"
                shift 2
                ;;
            --iterations)
                FORMAL_ITERATIONS="$2"
                shift 2
                ;;
            --warmup)
                FORMAL_WARMUP="$2"
                shift 2
                ;;
            --rtt)
                RTT_MS="$2"
                shift 2
                ;;
            --initcwnd)
                INITCWND_MSS="$2"
                shift 2
                ;;
            --iface)
                NETEM_IFACE="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "[ERR] unknown argument: $1"
                usage
                exit 1
                ;;
        esac
    done
}

parse_args "$@"

if [[ ! -x "$RUNNER" ]]; then
    echo "[ERR] missing runner: $RUNNER"
    exit 1
fi

us_ts() {
    TZ=America/New_York date +%Y-%m-%dT%H:%M:%S%z
}

log_info() {
    printf '[%s][INFO] %s\n' "$(us_ts)" "$*"
}

mkdir -p "$OUT_DIR"

if ! FORMAL_ROUNDS="$FORMAL_ROUNDS" \
FORMAL_WARMUP="$FORMAL_WARMUP" \
FORMAL_ITERATIONS="$FORMAL_ITERATIONS" \
RTT_MS="$RTT_MS" \
INITCWND_MSS="$INITCWND_MSS" \
NETEM_IFACE="$NETEM_IFACE" \
TEST_HOST="$TEST_HOST" \
TEST_PORT="$TEST_PORT" \
RESULT_DIR="$RESULT_DIR" \
bash "$RUNNER"; then
    echo "[ERR] backend runner failed."
    exit 1
fi

log_info "test1 backend finished"

rm -f "$OUT_DIR/cases_manifest.csv" "$OUT_DIR/metadata.txt"

SUMMARY_CSV="$OUT_DIR/summary.csv"
ROUND_MEANS_CSV="$OUT_DIR/round_means_append.csv"
READABLE_MD="$OUT_DIR/readable.md"

echo "ts_us,round,case,mean_ms,count" > "$ROUND_MEANS_CSV"
NOW_TS="$(us_ts)"
awk -F, -v ts="$NOW_TS" '
    NR==1 { next }
    $3=="measure" && $7==0 {
        key=$2","$1
        sum[key]+=$8
        cnt[key]+=1
    }
    END {
        for (k in sum) {
            printf "%s,%s,%.3f,%d\n", ts, k, sum[k]/cnt[k], cnt[k]
        }
    }
' "$OUT_DIR/raw_runs.csv" | sort -t, -k2,2n -k3,3 >> "$ROUND_MEANS_CSV"

emit_row() {
    local notation="$1"
    awk -F, -v n="$notation" '$3==n{print $0; exit}' "$SUMMARY_CSV"
}

{
    echo "# test1 (Generated)"
    echo
    echo "Run config: rounds=$FORMAL_ROUNDS, warmup=$FORMAL_WARMUP, iterations=$FORMAL_ITERATIONS, RTT=${RTT_MS}ms, initcwnd=$INITCWND_MSS"
    echo
    echo "| Client Algorithm | Notation | NIST PQ Security | Mean (ms) | 50th (ms) | 95th (ms) |"
    echo "|---|---|---|---:|---:|---:|"

    for spec in \
        "Ed25519|ed25519|approx. 0 bits" \
        "ML-DSA-44|md44|Level 2" \
        "ML-DSA-65|md65|Level 3" \
        "ML-DSA-87|md87|Level 5" \
        "SLH-DSA-SHA2-128f|sd128f|Level 1" \
        "SLH-DSA-SHA2-192f|sd192f|Level 3" \
        "SLH-DSA-SHA2-256f|sd256f|Level 5" \
        "ML-KEM-512|mk512|Level 1" \
        "ML-KEM-768|mk768|Level 3" \
        "ML-KEM-1024|mk1024|Level 5"; do
        IFS='|' read -r display notation sec <<< "$spec"
        row="$(emit_row "$notation")"
        if [[ -z "$row" ]]; then
            echo "| $display | $notation | $sec | NA | NA | NA |"
            continue
        fi
        IFS=',' read -r _case _auth _paper _impl _status _reason mean p50 p95 _ <<< "$row"
        echo "| $display | $notation | $sec | $mean | $p50 | $p95 |"
    done
} > "$READABLE_MD"

echo "[OK] test1 complete"
echo "[ARTIFACT] $OUT_DIR/raw_runs.csv"
echo "[ARTIFACT] $OUT_DIR/round_means_append.csv"
echo "[ARTIFACT] $OUT_DIR/summary.csv"
echo "[ARTIFACT] $OUT_DIR/readable.md"
