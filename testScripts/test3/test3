#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
RUNNER="$ROOT_DIR/testScripts/backends/run_test3.sh"

OUT_DIR="$ROOT_DIR/testScripts/test3/results/test3"
RESULT_DIR="$OUT_DIR"

# Default reviewer mode (can be overridden by CLI options).
RTT_MS="${RTT_MS:-67}"
ROUNDS="${ROUNDS:-1}"
WARMUP="${WARMUP:-5}"
ITERATIONS="${ITERATIONS:-50}"
INITCWND_LIST="${INITCWND_LIST:-3 5 7 10 15 20 25 30 35 40 50}"
NETEM_IFACE="${NETEM_IFACE:-lo}"

usage() {
    cat <<'EOF'
Usage:
  bash testScripts/test3/test3 [options]

Options:
  --rounds <n>            Number of rounds (default: 1)
  --iterations <n>        Measured iterations per round (default: 50)
  --warmup <n>            Warmup iterations per round (default: 5)
  --rtt <ms>              RTT in milliseconds (default: 67)
  --initcwnd-list "..."   Space-separated window list
  --iface <name>          netem interface (default: lo)
  -h, --help              Show help
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rounds)
                ROUNDS="$2"
                shift 2
                ;;
            --iterations)
                ITERATIONS="$2"
                shift 2
                ;;
            --warmup)
                WARMUP="$2"
                shift 2
                ;;
            --rtt)
                RTT_MS="$2"
                shift 2
                ;;
            --initcwnd-list)
                INITCWND_LIST="$2"
                shift 2
                ;;
            --iface)
                NETEM_IFACE="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "[ERR] unknown argument: $1"
                usage
                exit 1
                ;;
        esac
    done
}

parse_args "$@"

if [[ ! -x "$RUNNER" ]]; then
    echo "[ERR] missing runner: $RUNNER"
    exit 1
fi

us_ts() {
    TZ=America/New_York date +%Y-%m-%dT%H:%M:%S%z
}

log_info() {
    printf '[%s][INFO] %s\n' "$(us_ts)" "$*"
}

mkdir -p "$OUT_DIR"

if ! RTT_MS="$RTT_MS" \
ROUNDS="$ROUNDS" \
WARMUP="$WARMUP" \
ITERATIONS="$ITERATIONS" \
INITCWND_LIST="$INITCWND_LIST" \
NETEM_IFACE="$NETEM_IFACE" \
RESULT_DIR="$RESULT_DIR" \
bash "$RUNNER"; then
    echo "[ERR] backend runner failed. Last logs:"
    exit 1
fi

log_info "test3 backend finished"

# Keep only the unified output set in testScripts.
rm -f "$OUT_DIR/test3_values.csv" "$OUT_DIR/test3_round_values.csv" "$OUT_DIR/metadata.txt"

RAW_CSV="$OUT_DIR/raw_runs.csv"
WINDOW_Q_CSV="$OUT_DIR/window_p5_p50_p95.csv"
ROUND_MEANS_CSV="$OUT_DIR/round_means_append.csv"
SUMMARY_CSV="$OUT_DIR/summary.csv"
READABLE_MD="$OUT_DIR/readable.md"

get_q() {
    local win="$1"
    local case_id="$2"
    local col="$3"
    awk -F, -v w="$win" -v c="$case_id" -v q="$col" '
        NR==1 {
            for (i=1; i<=NF; i++) {
                if ($i==q) idx=i
            }
            next
        }
        $1==w && $2==c {
            if (idx>0) print $idx
            exit
        }
    ' "$WINDOW_Q_CSV"
}

echo "ts_us,round,window,case,mean_ms,count" > "$ROUND_MEANS_CSV"
NOW_TS="$(us_ts)"
awk -F, -v ts="$NOW_TS" '
    NR==1 { next }
    $4=="measure" && $6==0 {
        key=$2","$1","$3
        sum[key]+=$7
        cnt[key]+=1
    }
    END {
        for (k in sum) {
            printf "%s,%s,%.3f,%d\n", ts, k, sum[k]/cnt[k], cnt[k]
        }
    }
' "$RAW_CSV" | sort -t, -k2,2n -k3,3n -k4,4 >> "$ROUND_MEANS_CSV"

echo "window,case,mean_ms,p50_ms,p95_ms,count" > "$SUMMARY_CSV"
for win in $INITCWND_LIST; do
    for case_id in A B C D E; do
        mean_and_count="$(awk -F, -v w="$win" -v c="$case_id" '
            NR==1 { next }
            $1==w && $3==c {
                sum+=$7; cnt+=1
            }
            END {
                if (cnt>0) printf "%.3f,%d", sum/cnt, cnt
            }
        ' "$RAW_CSV")"
        if [[ -z "$mean_and_count" ]]; then
            continue
        fi
        mean_ms="${mean_and_count%%,*}"
        count="${mean_and_count##*,}"
        p50="$(get_q "$win" "$case_id" p50)"
        p95="$(get_q "$win" "$case_id" p95)"
        echo "$win,$case_id,$mean_ms,${p50:-NA},${p95:-NA},$count" >> "$SUMMARY_CSV"
    done
done

{
    echo "# test3 (Generated)"
    echo
    echo "Run config: rounds=$ROUNDS, warmup=$WARMUP, iterations=$ITERATIONS, RTT=${RTT_MS}ms"
    echo
    echo "| initcwnd (MSS) | Case | Mean (ms) | 50th (ms) | 95th (ms) |"
    echo "|---:|---|---:|---:|---:|"

    for win in $INITCWND_LIST; do
        for case_id in A B C D E; do
            row="$(awk -F, -v w="$win" -v c="$case_id" '$1==w && $2==c {print $0; exit}' "$SUMMARY_CSV")"
            if [[ -z "$row" ]]; then
                echo "| $win | $case_id | NA | NA | NA |"
                continue
            fi
            IFS=',' read -r _w _c mean p50 p95 _count <<< "$row"
            echo "| $win | $case_id | $mean | $p50 | $p95 |"
        done
    done
} > "$READABLE_MD"

echo "[OK] test3 complete"
echo "[ARTIFACT] $OUT_DIR/raw_runs.csv"
echo "[ARTIFACT] $OUT_DIR/round_means_append.csv"
echo "[ARTIFACT] $OUT_DIR/summary.csv"
echo "[ARTIFACT] $OUT_DIR/readable.md"

rm -f "$WINDOW_Q_CSV"
